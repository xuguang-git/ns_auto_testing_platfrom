DEBUG=true
SECRET_KEY=replace-with-a-long-random-secret
ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://localhost:5173

DB_NAME=replace-with-db-name
DB_USER=replace-with-db-user
DB_PASSWORD=replace-with-db-password
DB_HOST=127.0.0.1
DB_PORT=5432

# Redis只保存队列、缓存和临时状态，不保存长期业务数据
# DB 1：Celery队列和任务结果；DB 2：Django缓存
REDIS_URL=redis://127.0.0.1:6379/1
DJANGO_CACHE_URL=redis://127.0.0.1:6379/2
CELERY_RESULT_EXPIRES=86400

# 仅限本地开发。除非调试执行器是隔离的，否则在生产环境中应保持为false。
API_DEBUG_ALLOW_PRIVATE_NETWORK=false

# 认证有效期。访问令牌默认为1天；刷新令牌保持登录连续性
ACCESS_TOKEN_SECONDS=86400
REFRESH_TOKEN_SECONDS=1296000
REMEMBER_ME_REFRESH_TOKEN_SECONDS=2592000
USER_SESSION_SECONDS=86400
REMEMBER_ME_USER_SESSION_SECONDS=2592000

# 测试数据源使用的外部数据库连接请在「数据库管理」页面维护，运行期不再从 .env 读取。
