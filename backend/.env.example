DEBUG=true
SECRET_KEY=replace-with-a-long-random-secret
ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://localhost:5173

DB_NAME=replace-with-db-name
DB_USER=replace-with-db-user
DB_PASSWORD=replace-with-db-password
DB_HOST=127.0.0.1
DB_PORT=3306

# Redis配置保留，待基础设施确认后再进行替换
REDIS_URL=redis://127.0.0.1:6379/0

# 仅限本地开发。除非调试执行器是隔离的，否则在生产环境中应保持为false。
API_DEBUG_ALLOW_PRIVATE_NETWORK=false

# 认证有效期。访问令牌默认为1天；刷新令牌保持登录连续性
ACCESS_TOKEN_SECONDS=86400
REFRESH_TOKEN_SECONDS=1296000
REMEMBER_ME_REFRESH_TOKEN_SECONDS=2592000
USER_SESSION_SECONDS=86400
REMEMBER_ME_USER_SESSION_SECONDS=2592000

# 测试数据数据库连接示例。使用只读数据库账号
# 数据库管理读取此列表，并将连接显示为只读行
TEST_DATA_DB_CONNECTIONS=TEST_ORDER_DB
# TEST_ORDER_DB_ENVIRONMENT=test
# TEST_ORDER_DB_DISPLAY_NAME=Order test readonly DB
# TEST_ORDER_DB_ENABLED=true
# TEST_ORDER_DB_TYPE=postgresql
